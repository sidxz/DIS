# Database
DATABASE_URL=postgresql+asyncpg://identity:identity_dev@localhost:9001/identity

# Redis
REDIS_URL=redis://localhost:9002/0

# JWT keys (generate with: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem)
JWT_PRIVATE_KEY_PATH=keys/private.pem
JWT_PUBLIC_KEY_PATH=keys/public.pem
JWT_ALGORITHM=RS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# OAuth2 providers
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Microsoft EntraID (optional)
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
ENTRA_TENANT_ID=

# Service
SERVICE_HOST=0.0.0.0
SERVICE_PORT=9003
BASE_URL=http://localhost:9003
FRONTEND_URL=http://localhost:3000

# Session secret (generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
SESSION_SECRET_KEY=

# Allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000

# Security
COOKIE_SECURE=false                   # Set true in production (requires HTTPS)
ALLOWED_HOSTS=*                       # Comma-separated hostnames; * = allow all (dev only)
SERVICE_API_KEYS=                     # Comma-separated; empty = no enforcement (dev only)
